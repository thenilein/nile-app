VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# MSG91 OTP widget credentials
VITE_MSG91_TOKEN_AUTH=your_msg91_widget_token_here
# Optional fallback if token auth is not set
VITE_MSG91_AUTH_KEY=your_msg91_auth_key_here
VITE_MSG91_WIDGET_ID=your_msg91_widget_id_here
# Mapbox Geocoding API (public token; restrict by URL in Mapbox dashboard)
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_default_public_token_here
